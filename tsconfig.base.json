{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "CommonJS",
    "esModuleInterop": true,
    "lib": [
      "ES2022"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@must-iq/shared-types": [
        "libs/shared-types/src/index.ts"
      ],
      "@must-iq/shared-types/*": [
        "libs/shared-types/src/*"
      ],
      "@must-iq/db": [
        "libs/db/src/index.ts"
      ],
      "@must-iq/db/*": [
        "libs/db/src/*"
      ],
      "@must-iq/config": [
        "libs/config/src/index.ts"
      ],
      "@must-iq/config/*": [
        "libs/config/src/*"
      ],
      "@must-iq/langchain": [
        "langchain/src/index.ts"
      ],
      "@must-iq/langchain/*": [
        "langchain/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}