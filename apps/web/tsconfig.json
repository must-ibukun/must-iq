{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@must-iq-web/*": [
        "src/*"
      ],
      "@must-iq/shared-types": [
        "../../libs/shared-types/src/index.ts"
      ],
      "@must-iq/shared-types/*": [
        "../../libs/shared-types/src/*"
      ],
      "@must-iq/db": [
        "../../libs/db/src/index.ts"
      ],
      "@must-iq/db/*": [
        "../../libs/db/src/*"
      ],
      "@must-iq/config": [
        "../../libs/config/src/index.ts"
      ],
      "@must-iq/config/*": [
        "../../libs/config/src/*"
      ],
      "@must-iq/langchain": [
        "../../langchain/src/index.ts"
      ],
      "@must-iq/langchain/*": [
        "../../langchain/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "build/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
