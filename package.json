{
  "name": "must-iq",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "langchain"
  ],
  "scripts": {
    "--- API BE ---": "----------------------------------------",
    "dev": "nx run api:dev",
    "build": "nx run api:build",
    "test": "nx run api:test",
    "token:report": "nx run api:token-report",
    "--- WEB FE ---": "----------------------------------------",
    "web:dev": "nx run web:dev",
    "web:build": "nx run web:build",
    "web:start": "nx run web:start",
    "web:lint": "nx run web:lint",
    "--- DATABASE ---": "----------------------------------------",
    "db:generate": "npx prisma generate --schema=libs/db/src/prisma/schema.prisma",
    "db:migrate": "npm run db:generate && npm run migration:run",
    "db:seed": "ts-node libs/db/src/seed.ts",
    "db:studio": "npx prisma studio --schema=libs/db/src/prisma/schema.prisma",
    "migration:dev": "npx prisma generate --schema=libs/db/src/prisma/schema.prisma && npm run migration:run",
    "migration:generate": "npx prisma generate --schema=libs/db/src/prisma/schema.prisma && npx prisma migrate dev --create-only --name --schema=libs/db/src/prisma/schema.prisma",
    "migration:revert": "npx prisma migrate revert --schema=libs/db/src/prisma/schema.prisma",
    "migration:run": "npx prisma migrate deploy --schema=libs/db/src/prisma/schema.prisma",
    "--- MONOREPO ---": "----------------------------------------",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "graph": "nx graph",
    "ingest": "nx run ai-engine:ingest"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.22",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.31",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.12",
    "@langchain/textsplitters": "^1.0.1",
    "@langchain/weaviate": "^1.0.1",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/common": "^11.0.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.16",
    "@slack/web-api": "^7.15.0",
    "@types/crypto-js": "^4.2.2",
    "@types/pg": "^8.18.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "adm-zip": "^0.5.16",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "crypto-js": "^4.2.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "langchain": "^1.2.30",
    "mermaid": "^11.13.0",
    "next": "^15.5.12",
    "next-themes": "^0.4.6",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.4",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "weaviate-client": "^3.12.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@nx/eslint": "^22.0.0",
    "@nx/js": "^22.0.0",
    "@nx/nest": "^22.5.4",
    "@nx/next": "^22.0.0",
    "@nx/node": "^22.0.0",
    "@nx/workspace": "^22.0.0",
    "@prisma/client": "^6.19.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "nx": "^22.0.0",
    "prettier": "^3.2.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">= 20.0.0",
    "npm": ">= 10.0.0"
  }
}