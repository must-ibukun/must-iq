# Dependencies — reinstalled inside the build container
node_modules
**/node_modules

# Next.js build output — rebuilt inside the container
apps/web/.next
apps/web/build
dist

# Nx cache
.nx/cache
tmp

# Git
.git
.gitignore

# Logs
*.log
npm-debug.log*

# Local env files — never bake secrets into an image
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.vscode
.idea
*.swp

# Test output
coverage
